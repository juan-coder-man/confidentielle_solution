confidentielle_MOCK=true

# Frontend (apps/web) — public key is safe for browser
VITE_API_URL=http://localhost:3000
VITE_confidentielle_MOCK=true
VITE_confidentielle_PUBLIC_KEY=
VITE_confidentielle_BASE_URL=https://api-sandbox.co.uat.confidentielle.dev/v1
