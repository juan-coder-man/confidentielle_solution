# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=checkout
DATABASE_PASSWORD=checkout
DATABASE_NAME=checkout_db

# API (apps/api)
API_PORT=3000
CORS_ORIGIN=http://localhost:5173

# confidentielle Sandbox (server: private key only — never commit real keys)
confidentielle_BASE_URL=https://api-sandbox.co.uat.confidentielle.dev/v1
